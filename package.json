{
  "name": "nsmp",
  "version": "1.0.0",
  "description": "Nostr Stealth Messaging Protocol — metadata-resistant, forward-secret, relay-hopping messaging",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nsmp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "commander": "^12.0.0",
    "nostr-tools": "^2.7.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "nostr",
    "nsmp",
    "stealth-messaging",
    "metadata-resistant",
    "forward-secrecy",
    "relay-hopping",
    "encrypted-messaging",
    "nip-44",
    "privacy",
    "pwa",
    "passkey",
    "webauthn"
  ],
  "license": "LGPL-3.0-only"
}
